{
  "$id": "https://openclaw.ai/schemas/agent-contract/behavior-contract.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Behavior Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "role",
    "objective",
    "guardrails",
    "escalation",
    "outputContract",
    "toolsUsed"
  ],
  "properties": {
    "role": {
      "type": "string",
      "minLength": 3
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "defs.common.json#/$defs/longText"
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when",
        "action"
      ],
      "properties": {
        "when": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "defs.common.json#/$defs/longText"
          }
        },
        "action": {
          "$ref": "defs.common.json#/$defs/shortText"
        }
      }
    },
    "outputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "requiredSections"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "markdown",
            "json",
            "text"
          ]
        },
        "requiredSections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "defs.common.json#/$defs/shortText"
          }
        }
      }
    },
    "toolsUsed": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "pattern": "^[a-z][a-z0-9-_]*$",
        "type": "string"
      }
    }
  }
}
